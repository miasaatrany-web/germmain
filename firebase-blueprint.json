{
  "entities": {
    "Setting": {
      "title": "Setting",
      "description": "Global settings for the application.",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "logoUrl": { "type": "string" },
        "phone": { "type": "string" },
        "whatsapp": { "type": "string" },
        "address": { "type": "string" },
        "facebookUrl": { "type": "string" },
        "instagramUrl": { "type": "string" },
        "tiktokUrl": { "type": "string" },
        "youtubeUrl": { "type": "string" },
        "heroImage": { "type": "string" },
        "description": { "type": "string" },
        "hours": { "type": "string" },
        "primaryColor": { "type": "string" }
      }
    },
    "Service": {
      "title": "Service",
      "description": "Metalwork service offered by the workshop.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "imageUrl": { "type": "string" }
      },
      "required": ["title", "description", "icon"]
    },
    "Category": {
      "title": "Category",
      "description": "Project category.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" }
      },
      "required": ["name", "slug"]
    },
    "Project": {
      "title": "Project",
      "description": "A metalwork project completed or in-progress.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "date": { "type": "string" },
        "photos": { "type": "array" },
        "videos": { "type": "array" },
        "location": { "type": "string" },
        "client": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["title", "description", "category", "date", "status"]
    },
    "Message": {
      "title": "Message",
      "description": "Contact message sent by a visitor.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["name", "phone", "message", "createdAt"]
    },
    "AiHistory": {
      "title": "AiHistory",
      "description": "AI generated social media posts and copy for a project.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "facebookPosts": { "type": "array" },
        "instagramPosts": { "type": "array" },
        "whatsappPosts": { "type": "array" },
        "linkedinPosts": { "type": "array" },
        "seoTitle": { "type": "string" },
        "seoDescription": { "type": "string" },
        "hashtags": { "type": "array" },
        "projectDesc": { "type": "string" },
        "professionalSummary": { "type": "string" },
        "adIdeas": { "type": "array" },
        "createdAt": { "type": "string" }
      },
      "required": ["projectId", "createdAt"]
    }
  },
  "firestore": {
    "/settings/{settingsId}": {
      "schema": "Setting",
      "description": "Singleton configuration settings."
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Offered metalwork services."
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Project categories."
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Metalwork realizations."
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Inbound client contact submissions."
    },
    "/ai_history/{historyId}": {
      "schema": "AiHistory",
      "description": "Generated AI marketing posts and metadata."
    }
  }
}
